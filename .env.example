# ── Banco de dados ──────────────────────────────────────────────────
# Dev local (docker-compose): usar o valor abaixo
# QA/Prod: URL do serviço gerenciado (Cloud SQL, Supabase, Railway, etc.)
DATABASE_URL=postgresql+asyncpg://rotulos_user:rotulos_pass@localhost:5432/rotulos_db

# ── Segurança ────────────────────────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua_por_chave_aleatoria_de_64_chars_hex

# ── Google Cloud Vision ─────────────────────────────────────────────
# Path para o arquivo de service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/service_account.json

# ── Tesseract ────────────────────────────────────────────────────────
# Normalmente configurado pelo Dockerfile; sobrescrever apenas se necessário
# TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata

# ── Upload ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────────────
# Em produção: restringir para o domínio do app mobile
# ALLOWED_ORIGINS=https://meuapp.com,https://app.meuapp.com
