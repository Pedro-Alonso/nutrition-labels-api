{
  "name": "otsu_basic",
  "description": "Preset clássico da literatura: CLAHE leve, median blur e limiarização de Otsu. Primeira escolha por ser rápido e defensável academicamente.",
  "kind": "linear_table",
  "priority": 10,
  "steps": [
    {"op": "resize_max_height", "name": "resize_max_h500", "max_height": 500},
    {"op": "grayscale", "name": "grayscale"},
    {"op": "clahe", "name": "clahe", "clip_limit": 2.0, "tile_grid_size": [8, 8]},
    {"op": "median_blur", "name": "median_blur", "kernel_size": 3},
    {"op": "otsu_threshold", "name": "otsu_threshold"},
    {"op": "ensure_black_text_on_white", "name": "ensure_polarity"}
  ],
  "ocr": {
    "lang": "por",
    "psm": 6,
    "oem": 3,
    "dual_pass_polarity": true
  },
  "quality_thresholds": {
    "min_mean_confidence": 65,
    "min_text_length": 40,
    "min_keyword_hits": 3,
    "expected_keywords": [
      "valor energetico",
      "carboidratos",
      "proteinas",
      "gorduras totais",
      "gorduras saturadas",
      "sodio"
    ]
  }
}
