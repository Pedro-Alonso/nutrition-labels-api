{
  "name": "ingredient_psm6_adaptive",
  "description": "Fallback para lista de ingredientes com iluminação irregular. PSM 6 (bloco uniforme) com adaptive threshold. Usar quando o Otsu perde texto por contraste irregular.",
  "kind": "linear_ingredient",
  "priority": 20,
  "steps": [
    {"op": "resize_max_height",   "name": "resize_max_h900",  "max_height": 900},
    {"op": "grayscale",           "name": "grayscale"},
    {"op": "clahe",               "name": "clahe", "clip_limit": 3.0, "tile_grid_size": [8, 8]},
    {"op": "gaussian_blur",       "name": "gaussian_blur", "kernel_size": 3},
    {"op": "adaptive_threshold",  "name": "adaptive_threshold", "block_size": 31, "c": 10},
    {"op": "ensure_black_text_on_white", "name": "ensure_polarity"}
  ],
  "ocr": {
    "lang": "por",
    "psm": 6,
    "oem": 3,
    "extra_config": "",
    "dual_pass_polarity": true
  },
  "quality_thresholds": {
    "min_mean_confidence": 45,
    "min_text_length": 20,
    "min_keyword_hits": 1,
    "expected_keywords": ["ingredientes", "contem", "acucar", "sal", "farinha", "oleo", "gordura", "amido"]
  }
}
